{
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "github": {
    "enabled": true,
    "silent": true
  },
  "regions": ["fra1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" }
      ]
    }
  ]
}
